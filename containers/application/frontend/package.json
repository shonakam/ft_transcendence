{
  "name": "frontend",
  "version": "1.0.0",
  "main": "main.ts",
  "scripts": {
    "dev": "concurrently \"npm:dev:css\" \"npm:dev:html\"",
    "dev:css": "npx @tailwindcss/cli -i ./src/input.css -o ./src/output.css --watch",
    "dev:html": "vite build --watch",
    "build": "npm run build:css && vite build",
    "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./dist/output.css",
    "preview": "vite preview",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "format": "prettier --write './src/**/*.ts'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@tailwindcss/cli": "^4.1.13",
    "@shonakam/common": "file:../common",
    "qrcode": "^1.5.4",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.1.13"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.1",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.2.1",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.1.3",
    "ts-jest": "^29.4.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.4"
  }
}
