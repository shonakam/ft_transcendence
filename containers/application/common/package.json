{
  "name": "@shonakam/common",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./src/*.ts",
      "default": "./dist/*.js",
      "types": "./dist/*.d.ts"
    },
    "./*.ts": {
      "import": "./src/*.ts",
      "default": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint --cache --ext .ts .",
    "lint:fix": "eslint --cache --fix --ext .ts .",
    "format": "prettier --write './src/**/*.ts'"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.1.3",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
