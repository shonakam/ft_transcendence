{
	"compilerOptions": {
		"target": "ES2022",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"outDir": "./dist",
		"baseUrl": ".",
		"composite": true,
		"declaration": true,
		"declarationMap": true
	},
	"include": [
		"src/**/*"
	]
}
