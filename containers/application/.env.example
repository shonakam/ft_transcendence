# Docker Configure
# Copy this file to .env.local and fill in the values
# NEVER commit real secrets to this file!

DATA_DIR=/path/to/your/data

ENV_DOMAIN_NAME=transcendence.42.fr
VITE_API_BASE_URL="/api/"

FRONTEND_HOST_PORT=5173
FRONTEND_CONTAINER_PORT=5173

BACKEND_HOST_PORT=8080
BACKEND_CONTAINER_PORT=8080

REDIS_HOST_PORT=6379
REDIS_CONTAINER_PORT=6379

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# These secrets should be stored in Vault in production
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_TMP_AUTH_SECRET=""

# OIDC Credentials - Store actual values in Vault
FT_REDIRECT_URL=""
VITE_42_REDIRECT_URI="https://transcendence.42.fr/auth/callback"
VITE_42_CLIENT_ID=""
VITE_42_CLIENT_SECRET=""

# Vault Configuration
VAULT_ENDPOINT=https://vault:8200
VAULT_TOKEN=
VAULT_SKIP_VERIFY=true
